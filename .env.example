POSTGRES_DB=nlp2sql_demo
POSTGRES_USER=nlp2sql
POSTGRES_PASSWORD=nlp2sql_password
DATABASE_URL=postgresql+psycopg2://nlp2sql:nlp2sql_password@localhost:5432/nlp2sql_demo
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=nlp2sql
REDIS_DEFAULT_TTL_SECONDS=3600
DB_SCHEMA=public
LOG_LEVEL=INFO
VECTOR_STORE_PROVIDER=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=nlp2sql_schema
VECTOR_STORE_STARTUP_RETRIES=10
VECTOR_STORE_STARTUP_RETRY_DELAY_SECONDS=1.5
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash-v1
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=16
EMBEDDING_TIMEOUT_SECONDS=10
LLM_PROVIDER=mock
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock-llm
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1
SQL_DEFAULT_LIMIT=100
SQL_MAX_LIMIT=500
SQL_STATEMENT_TIMEOUT_MS=5000
SQL_EXECUTOR_MAX_ROWS=500
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8080
VITE_API_TIMEOUT_MS=180000
